# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=codeatlas
DATABASE_URL=postgresql://postgres:postgres@codeatlas-postgres:5432/codeatlas

# Cache Configuration
REDIS_URL=redis://codeatlas-redis:6379/0

# Security Configuration
# WARNING: Change this value in production environments
SECRET_KEY=supersecretjwtkey123!
JWT_ISSUER=codeatlas
JWT_AUDIENCE=codeatlas-api

# AI Services Configuration
# Provide your OpenAI API key for engine analysis
OPENAI_API_KEY=your_openai_api_key_here
